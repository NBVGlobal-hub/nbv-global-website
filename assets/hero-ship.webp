/* NBV Global Enterprises — B2B export site
   Brand: logo blue + slate grey, warm amber accent, paper base.
   Type: Newsreader (display serif) + Hanken Grotesk (body) + IBM Plex Mono (specs) */

:root{
  --blue:#1a56a3;        /* logo blue */
  --blue-deep:#123f77;
  --blue-ink:#0e2a4d;
  --slate:#5b6774;       /* logo grey */
  --ink:#16212e;         /* near-black text */
  --ink-2:#0d151f;       /* dark section bg */
  --paper:#f7f4ec;       /* warm off-white */
  --paper-2:#efe9dc;
  --line:#e2dccd;
  --amber:#c2822c;       /* warm accent (jaggery/spice) */
  --amber-soft:#e9c88a;
  --white:#ffffff;
  --muted:#6b7480;

  --serif:'Newsreader',Georgia,serif;
  --sans:'Hanken Grotesk',system-ui,sans-serif;
  --mono:'IBM Plex Mono',ui-monospace,monospace;

  --wrap:1180px;
  --r:14px;
  --shadow:0 18px 50px -22px rgba(14,42,77,.35);
  --ease:cubic-bezier(.2,.7,.2,1);
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden;width:100%}
body{
  font-family:var(--sans);
  color:var(--ink);
  background:var(--paper);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
picture{display:block;height:100%}
.wrap{max-width:var(--wrap);margin:0 auto;padding:0 clamp(20px,5vw,44px)}

/* ---------- Typography ---------- */
h1,h2,h3{font-family:var(--serif);font-weight:500;line-height:1.08;letter-spacing:-.01em;color:var(--ink)}
h1{font-size:clamp(2.5rem,6vw,4.4rem)}
h2{font-size:clamp(1.9rem,3.6vw,2.9rem)}
h3{font-size:1.28rem;letter-spacing:0}
h1 em,h2 em{font-style:italic;font-weight:400;color:var(--blue)}
p{color:#3a4550}
.dark h1,.dark h2,.dark h3{color:#f4f1e9}
.dark p{color:#c3cbd4}

.eyebrow{
  font-family:var(--mono);font-size:.72rem;font-weight:500;
  letter-spacing:.22em;text-transform:uppercase;color:var(--blue);
  margin-bottom:1rem;display:inline-block;
}
.eyebrow.light{color:var(--amber-soft)}
.eyebrow::before{content:"";display:inline-block;width:26px;height:1px;background:currentColor;vertical-align:middle;margin-right:12px;opacity:.6}
.eyebrow.center{display:block;text-align:center}
.eyebrow.center::before{display:none}

.hsn{font-family:var(--mono);font-size:.72rem;letter-spacing:.12em;color:var(--slate);text-transform:uppercase}
.hsn.big{display:inline-block;background:var(--paper-2);color:var(--blue-deep);padding:5px 12px;border-radius:6px;margin-bottom:1rem;font-weight:500}
.alt{font-style:italic;color:var(--slate);font-size:.7em;font-family:var(--serif)}

.text-link{font-weight:600;color:var(--blue);font-size:.92rem;transition:.25s var(--ease)}
.text-link:hover{color:var(--amber);letter-spacing:.01em}
.lead-line{font-size:1.08rem;color:var(--ink);font-weight:500}

/* ---------- Buttons ---------- */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.5em;
  font-family:var(--sans);font-weight:600;font-size:.95rem;
  padding:.85em 1.6em;border-radius:100px;cursor:pointer;border:1.5px solid transparent;
  transition:.3s var(--ease);white-space:normal;text-align:center;max-width:100%;
}
.btn-solid{background:var(--blue);color:#fff}
.btn-solid:hover{background:var(--blue-deep);transform:translateY(-2px);box-shadow:0 12px 30px -10px rgba(26,86,163,.6)}
.btn-ghost{border-color:rgba(255,255,255,.5);color:#fff}
.btn-ghost:hover{background:rgba(255,255,255,.12);border-color:#fff}

/* ---------- Header ---------- */
.site-header{
  position:fixed;top:0;left:0;right:0;z-index:100;
  transition:.35s var(--ease);
  background:rgba(247,244,236,.96);backdrop-filter:blur(12px);box-shadow:0 1px 0 var(--line);
}
.site-header.scrolled{background:rgba(247,244,236,.96);backdrop-filter:blur(12px);box-shadow:0 1px 0 var(--line)}
.header-inner{display:flex;align-items:center;gap:24px;padding:14px 0;transition:padding .3s}
.site-header.scrolled .header-inner{padding:10px 0}
.brand{display:flex;align-items:center;position:relative}
/* logo: always dark version on light header; scales down on mobile */
.brand img{height:clamp(42px,5.6vw,58px);width:auto;transition:.3s}
.site-header.scrolled .brand img{height:clamp(40px,5.2vw,52px)}
.logo-light{display:none}
.logo-dark{opacity:1}
.nav{margin-left:auto}
.nav ul{display:flex;gap:6px;list-style:none;align-items:center}
.nav a{
  font-weight:500;font-size:.92rem;padding:9px 14px;border-radius:8px;color:var(--ink);
  transition:.2s;position:relative;
}
.nav a:hover{color:var(--blue);background:rgba(26,86,163,.07)}
.nav a[aria-current]{color:var(--blue)}
.nav a[aria-current]::after{content:"";position:absolute;left:14px;right:14px;bottom:3px;height:2px;background:var(--amber);border-radius:2px}
.has-menu{position:relative}
.submenu{
  position:absolute;top:100%;left:0;min-width:250px;background:#fff;border:1px solid var(--line);
  border-radius:12px;box-shadow:var(--shadow);padding:8px;opacity:0;visibility:hidden;
  transform:translateY(8px);transition:.25s var(--ease);
}
.has-menu:hover .submenu{opacity:1;visibility:visible;transform:translateY(0)}
.submenu a{display:block;padding:10px 12px;border-radius:8px;font-size:.9rem}
.submenu a:hover{background:var(--paper-2)}
.header-cta{padding:.62em 1.3em;font-size:.9rem}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;margin-left:auto}
.burger span{width:24px;height:2px;background:var(--ink);border-radius:2px;transition:.3s}
.burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.burger[aria-expanded="true"] span:nth-child(2){opacity:0}
.burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

.mobile-menu{
  position:fixed;top:0;right:0;bottom:0;width:min(80vw,340px);z-index:99;
  background:var(--ink-2);padding:90px 26px 30px;display:flex;flex-direction:column;gap:2px;
  transform:translateX(100%);transition:.4s var(--ease);
}
.mobile-menu.open{transform:translateX(0)}
.mobile-menu a{color:#e7ecf1;padding:13px 4px;font-size:1.05rem;font-weight:500;border-bottom:1px solid rgba(255,255,255,.08)}
.mobile-menu a.sub{padding-left:16px;font-size:.9rem;color:#9aa6b2;border-bottom:none}
.mobile-menu .btn{justify-content:center;border:none}

/* ---------- Hero (home) ---------- */
.hero{position:relative;min-height:92vh;display:flex;align-items:center;padding:120px 0 70px;overflow:hidden}
.hero-bg{position:absolute;inset:0;z-index:0}
.hero-bg img{width:100%;height:100%;object-fit:cover}
.hero-scrim{position:absolute;inset:0;background:
  linear-gradient(105deg,rgba(9,26,48,.94) 0%,rgba(12,35,64,.8) 42%,rgba(14,42,77,.35) 100%);}
.hero-inner{position:relative;z-index:2;max-width:800px}
.hero h1{color:#fff;margin:.2em 0 .45em}
.hero h1 em{color:var(--amber-soft)}
.hero-lead{color:#d7dee6;font-size:clamp(1.05rem,1.8vw,1.28rem);max-width:640px}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;margin:2.2rem 0}
.hero-strip{list-style:none;display:flex;flex-wrap:wrap;gap:36px;margin-top:2.4rem;padding-top:1.8rem;border-top:1px solid rgba(255,255,255,.16)}
.hero-strip strong{font-family:var(--serif);font-size:1.7rem;color:#fff;font-weight:500;display:block;line-height:1}
.hero-strip span{font-family:var(--mono);font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--amber-soft);margin-top:6px;display:block}

/* ---------- Sections ---------- */
section{padding:clamp(64px,9vw,120px) 0}
.section-head{max-width:640px;margin-bottom:clamp(36px,5vw,58px)}
.dark{background:var(--ink-2);position:relative}

/* intro */
.intro-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:clamp(30px,6vw,80px);align-items:start}
.intro-body p{margin-bottom:1.1em;font-size:1.05rem}
.intro-body .text-link{margin-top:.4rem;display:inline-block}

/* portfolio grid */
.prod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
.prod-card{background:#fff;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;transition:.35s var(--ease);display:flex;flex-direction:column}
.prod-card:hover{transform:translateY(-6px);box-shadow:var(--shadow);border-color:#d5cdb8}
.prod-img{aspect-ratio:4/3;overflow:hidden;background:var(--ink-2)}
.prod-img img{width:100%;height:100%;object-fit:cover;transition:.6s var(--ease)}
.prod-card:hover .prod-img img{transform:scale(1.06)}
.prod-meta{padding:22px 22px 26px;display:flex;flex-direction:column;flex:1}
.prod-meta h3{margin:.5rem 0 .5rem}
.prod-meta p{font-size:.95rem;flex:1;margin-bottom:1rem}

/* why cards */
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.09);border-radius:var(--r);overflow:hidden}
.why-card{background:var(--ink-2);padding:34px 30px}
.why-card .num{font-family:var(--mono);color:var(--amber);font-size:.85rem;letter-spacing:.1em}
.why-card h3{margin:.8rem 0 .6rem;color:#f4f1e9}
.why-card p{font-size:.95rem}
.cta-card{background:linear-gradient(140deg,var(--blue-deep),var(--blue-ink));display:flex;flex-direction:column;justify-content:center;gap:1.2rem}
.cta-card h3{color:#fff}

/* promise */
.promise{background:var(--paper-2);text-align:center}
.promise-words{display:flex;justify-content:center;gap:clamp(18px,4vw,46px);flex-wrap:wrap;margin:.5rem 0 1.4rem}
.promise-words span{font-family:var(--serif);font-style:italic;font-size:clamp(1.9rem,4.5vw,3.2rem);color:var(--blue)}
.promise-words span:nth-child(2){color:var(--slate)}
.promise-words span:nth-child(3){color:var(--amber)}
.promise-sub{max-width:560px;margin:0 auto 2rem;font-size:1.08rem}

/* page hero (interior) */
.page-hero{position:relative;padding:170px 0 70px;background:var(--ink-2);overflow:hidden}
.page-hero:not(.with-img){background:linear-gradient(150deg,var(--blue-ink),var(--ink-2))}
.page-hero h1{color:#fff;max-width:15ch}
.page-hero .eyebrow.light{color:var(--amber-soft)}
.page-hero-lead{color:#c9d2db;font-size:1.15rem;max-width:620px;margin-top:1.2rem}
.page-hero-lead.light{color:#d7dee6}
.page-hero-bg{position:absolute;inset:0;z-index:0}
.page-hero-bg img{width:100%;height:100%;object-fit:cover}
.page-hero.with-img .hero-scrim{background:linear-gradient(100deg,rgba(9,26,48,.92),rgba(12,35,64,.7))}
.page-hero.with-img .wrap{position:relative;z-index:2}

/* two-col */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,6vw,72px);align-items:center}
.two-col-media img{border-radius:var(--r);width:100%;aspect-ratio:4/5;object-fit:cover;box-shadow:var(--shadow)}
.two-col-body h2{margin:.4rem 0 1rem}
.two-col-body p{margin-bottom:1em;font-size:1.05rem}

/* about values */
.val-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
.val{padding:30px;border:1px solid rgba(255,255,255,.12);border-radius:var(--r);background:rgba(255,255,255,.02)}
.val h3{color:#f4f1e9;margin-bottom:.5rem}
.val h3::before{content:"";display:block;width:34px;height:3px;background:var(--amber);border-radius:2px;margin-bottom:16px}

/* buyers */
.buyer-list{list-style:none;display:flex;flex-wrap:wrap;gap:12px;margin:1.4rem 0}
.buyer-list li{font-family:var(--mono);font-size:.82rem;letter-spacing:.04em;padding:10px 18px;border:1px solid var(--line);border-radius:100px;background:#fff;color:var(--blue-deep)}
.buyers-note{max-width:640px;font-size:1.05rem;margin-bottom:1.8rem}

/* products list rows */
.prod-row{display:grid;grid-template-columns:1fr 1fr;gap:clamp(24px,5vw,64px);align-items:center;padding:clamp(30px,5vw,54px) 0;border-bottom:1px solid var(--line)}
.prod-row.reverse .prod-row-img{order:2}
.prod-row-img img{border-radius:var(--r);aspect-ratio:5/4;object-fit:cover;width:100%;box-shadow:var(--shadow);transition:.5s var(--ease)}
.prod-row:hover .prod-row-img img{transform:translateY(-5px)}
.prod-row-body h2{margin:.6rem 0 .8rem}
.prod-row-body p{font-size:1.05rem;margin-bottom:1.2rem;max-width:46ch}

/* product detail */
.prod-detail-hero{padding-top:150px;background:linear-gradient(180deg,var(--paper-2),var(--paper))}
.prod-detail-top{display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,5vw,66px);align-items:center}
.prod-detail-media img{border-radius:var(--r);width:100%;aspect-ratio:4/5;object-fit:cover;box-shadow:var(--shadow)}
.crumb{font-family:var(--mono);font-size:.75rem;letter-spacing:.08em;color:var(--slate);display:inline-block;margin-bottom:1.2rem}
.crumb:hover{color:var(--blue)}
.prod-detail-intro h1{font-size:clamp(2.1rem,4.5vw,3.3rem);margin-bottom:.5rem}
.tagline{font-family:var(--serif);font-style:italic;font-size:1.35rem;color:var(--amber);margin-bottom:1.3rem}
.prod-detail-intro p{font-size:1.03rem;margin-bottom:1em}
.prod-detail-intro .btn{margin-top:.8rem}

.prod-specs{padding-top:clamp(48px,6vw,80px)}
.specs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(26px,4vw,44px);margin-bottom:clamp(40px,5vw,60px)}
.spec-block h3{margin-bottom:1.2rem;padding-bottom:.8rem;border-bottom:2px solid var(--amber);display:inline-block}
.ticks{list-style:none;display:flex;flex-direction:column;gap:12px}
.ticks li{padding-left:30px;position:relative;font-size:.98rem}
.ticks li::before{content:"";position:absolute;left:0;top:8px;width:16px;height:9px;border-left:2px solid var(--blue);border-bottom:2px solid var(--blue);transform:rotate(-45deg)}
.ticks.light li{color:#d4dbe2}
.ticks.light li::before{border-color:var(--amber-soft)}
.chips{list-style:none;display:flex;flex-wrap:wrap;gap:10px}
.chips li{font-size:.86rem;padding:8px 15px;background:#fff;border:1px solid var(--line);border-radius:100px;color:var(--ink)}
.chips.pack li{font-family:var(--mono);font-size:.8rem;background:var(--paper-2);border-color:transparent;color:var(--blue-deep);font-weight:500}
.markets-note{background:#fff;border:1px solid var(--line);border-left:4px solid var(--amber);border-radius:var(--r);padding:30px 34px;max-width:760px}
.markets-note p{font-size:1.05rem;margin-bottom:.8rem}

/* cta band */
.cta-band{text-align:center}
.cta-band h2{margin-bottom:1.6rem;color:#fff}

/* quality steps */
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.step{padding:28px 24px;background:#fff;border:1px solid var(--line);border-radius:var(--r);border-top:3px solid var(--blue)}
.step .num{font-family:var(--mono);color:var(--amber);font-size:.85rem;font-weight:600}
.step h3{margin:.7rem 0 .5rem;font-size:1.15rem}
.step p{font-size:.93rem}
.two-col-side{display:flex;flex-direction:column;gap:18px}
.stat-card{background:linear-gradient(140deg,var(--blue-deep),var(--blue-ink));padding:30px;border-radius:var(--r)}
.stat-card strong{font-family:var(--serif);font-size:2.4rem;color:#fff;font-weight:500;display:block;line-height:1}
.stat-card span{color:var(--amber-soft);font-size:.9rem;margin-top:8px;display:block}

/* export markets */
.market-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px}
.market-card{padding:32px;background:#fff;border:1px solid var(--line);border-radius:var(--r);transition:.3s var(--ease)}
.market-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:#d5cdb8}
.market-card h3{margin-bottom:.5rem;color:var(--blue-deep)}
.support-list{list-style:none;display:flex;flex-direction:column;gap:14px}
.support-list li{font-family:var(--serif);font-size:1.2rem;color:#f4f1e9;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.12)}
.support-list li::before{content:"— ";color:var(--amber)}

/* contact */
.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(34px,6vw,72px);align-items:start}
.contact-info h2{margin-bottom:1.6rem}
.ci-item{margin-bottom:1.5rem}
.ci-label{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--slate);display:block;margin-bottom:.35rem}
.ci-item p{font-size:1.02rem;color:var(--ink)}
.ci-item a:hover{color:var(--blue)}
.contact-form{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:clamp(26px,4vw,40px);box-shadow:var(--shadow)}
.field{margin-bottom:18px;display:flex;flex-direction:column}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.field label{font-size:.82rem;font-weight:600;margin-bottom:7px;color:var(--slate)}
.field input,.field select,.field textarea{
  font-family:var(--sans);font-size:.98rem;padding:12px 14px;border:1.5px solid var(--line);
  border-radius:9px;background:var(--paper);color:var(--ink);transition:.2s;resize:vertical;
}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--blue);background:#fff;box-shadow:0 0 0 3px rgba(26,86,163,.12)}
.contact-form .btn{width:100%;justify-content:center;margin-top:6px}
.form-note{margin-top:16px;padding:14px;background:#eef6ee;border:1px solid #bcd9bc;border-radius:9px;color:#2c6b3f;font-size:.92rem;text-align:center}

/* ---------- Footer ---------- */
.site-footer{background:var(--ink-2);color:#c3cbd4;padding:70px 0 30px}
.footer-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1.3fr;gap:40px;padding-bottom:44px;border-bottom:1px solid rgba(255,255,255,.1)}
.foot-word{font-family:var(--serif);font-size:1.5rem;color:#fff;margin-bottom:.8rem;font-weight:500}
.foot-word span{color:var(--amber-soft);font-style:italic;font-size:1.1rem}
.foot-brand p{font-size:.92rem;max-width:34ch}
.foot-col h4{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--amber-soft);margin-bottom:1.1rem;font-weight:500}
.foot-col a{display:block;padding:6px 0;font-size:.94rem;color:#c3cbd4;transition:.2s}
.foot-col a:hover{color:#fff;padding-left:5px}
.foot-contact p{font-size:.92rem;margin-bottom:.9rem;line-height:1.7}
.foot-contact a:hover{color:var(--amber-soft)}
.foot-bottom{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;padding-top:24px;font-size:.82rem;color:#8a95a1}
.foot-tag{font-family:var(--mono);letter-spacing:.1em;color:var(--amber-soft)}

/* whatsapp */
.whatsapp{position:fixed;right:22px;bottom:22px;z-index:80;width:56px;height:56px;border-radius:50%;background:#25d366;color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 30px -6px rgba(37,211,102,.6);transition:.3s var(--ease)}
.whatsapp:hover{transform:scale(1.08) translateY(-2px)}

/* ---------- Reveal animation ---------- */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .8s var(--ease),transform .8s var(--ease)}
.reveal.in{opacity:1;transform:none}
.reveal.d1{transition-delay:.09s}
.reveal.d2{transition-delay:.18s}
.reveal.d3{transition-delay:.27s}
.reveal.d4{transition-delay:.36s}
@media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}

/* ---------- Responsive ---------- */
@media (max-width:960px){
  .nav,.header-cta{display:none}
  .burger{display:flex}
  .intro-grid,.two-col,.prod-detail-top,.contact-grid{grid-template-columns:1fr;gap:32px}
  .prod-grid,.why-grid,.val-grid,.specs-grid,.steps,.market-grid{grid-template-columns:repeat(2,1fr)}
  .prod-row,.prod-row.reverse{grid-template-columns:1fr}
  .prod-row .prod-row-img,.prod-row.reverse .prod-row-img{order:-1}
  .footer-grid{grid-template-columns:1fr 1fr}
  .two-col-media{max-width:440px}
}
@media (max-width:600px){
  .prod-grid,.why-grid,.val-grid,.specs-grid,.steps,.market-grid,.row2,.footer-grid{grid-template-columns:1fr}
  .hero{min-height:auto;padding-top:110px}
  .hero-strip{gap:26px}
  .promise-words{flex-direction:column;gap:6px}
}
